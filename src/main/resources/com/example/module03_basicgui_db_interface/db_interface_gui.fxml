<?xml version="1.0" encoding="UTF-8"?>

<?import java.net.URL?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Menu?>
<?import javafx.scene.control.MenuBar?>
<?import javafx.scene.control.MenuItem?>
<?import javafx.scene.control.SeparatorMenuItem?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.input.KeyCodeCombination?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<!--
    db_interface_gui.fxml — Main database interface layout
    Controller: DB_GUI_Controller
    Layout:
      Top    — MenuBar with File / Edit / Settings / Help menus (keyboard shortcuts included)
      Left   — Profile picture panel
      Center — Input form (First Name, Last Name, Department, Major) + CRUD buttons
      Right  — TableView displaying all Person records
      Bottom — Status bar label
-->
<AnchorPane
        fx:id="rootPane"
        maxHeight="-Infinity" maxWidth="-Infinity"
        minHeight="-Infinity" minWidth="-Infinity"
        prefHeight="535.0" prefWidth="807.0"
        xmlns="http://javafx.com/javafx/20.0.1"
        xmlns:fx="http://javafx.com/fxml/1"
        fx:controller="com.example.module03_basicgui_db_interface.DB_GUI_Controller">

   <children>
      <BorderPane layoutX="-2.0" layoutY="-1.0" prefHeight="535.0" prefWidth="807.0">

         <!-- ═══════════════════════════════════════════════════════════
              TOP — Menu Bar
              Keyboard shortcuts follow the pattern Ctrl + <letter>.
              Ctrl+F = open image   Ctrl+N = clear   Ctrl+Q = quit
              Ctrl+S = save/add     Ctrl+E = edit    Ctrl+D = delete
              Ctrl+T = toggle theme
         ═══════════════════════════════════════════════════════════ -->
         <top>
            <MenuBar BorderPane.alignment="CENTER">
               <menus>

                  <!-- File menu: application-level operations -->
                  <Menu mnemonicParsing="false" text="File">
                     <items>
                        <!-- Open a profile image; Ctrl+F chosen because F ≈ File/photo -->
                        <MenuItem mnemonicParsing="false" text="Open Image" onAction="#showImage">
                           <accelerator>
                              <KeyCodeCombination alt="UP" code="F" control="DOWN"
                                                 meta="UP" shift="UP" shortcut="UP"/>
                           </accelerator>
                        </MenuItem>

                        <!-- Clear the form; Ctrl+N ≈ "New" entry -->
                        <MenuItem mnemonicParsing="false" text="Clear Form" onAction="#clearForm">
                           <accelerator>
                              <KeyCodeCombination alt="UP" code="N" control="DOWN"
                                                 meta="UP" shift="UP" shortcut="UP"/>
                           </accelerator>
                        </MenuItem>

                        <SeparatorMenuItem/>

                        <!-- Exit the application; Ctrl+Q ≈ "Quit" -->
                        <MenuItem mnemonicParsing="false" text="Close" onAction="#closeApplication">
                           <accelerator>
                              <KeyCodeCombination alt="UP" code="Q" control="DOWN"
                                                 meta="UP" shift="UP" shortcut="UP"/>
                           </accelerator>
                        </MenuItem>
                     </items>
                  </Menu>

                  <!-- Edit menu: database CRUD operations -->
                  <Menu mnemonicParsing="false" text="Edit">
                     <items>
                        <!-- Add a new record; Ctrl+S ≈ "Save" -->
                        <MenuItem mnemonicParsing="false" text="Add Record" onAction="#addNewRecord">
                           <accelerator>
                              <KeyCodeCombination alt="UP" code="S" control="DOWN"
                                                 meta="UP" shift="UP" shortcut="UP"/>
                           </accelerator>
                        </MenuItem>

                        <!-- Edit the selected record; Ctrl+E ≈ "Edit" -->
                        <MenuItem mnemonicParsing="false" text="Edit Record" onAction="#editRecord">
                           <accelerator>
                              <KeyCodeCombination alt="UP" code="E" control="DOWN"
                                                 meta="UP" shift="UP" shortcut="UP"/>
                           </accelerator>
                        </MenuItem>

                        <!-- Delete the selected record; Ctrl+D ≈ "Delete" -->
                        <MenuItem mnemonicParsing="false" text="Delete Record" onAction="#deleteRecord">
                           <accelerator>
                              <KeyCodeCombination alt="UP" code="D" control="DOWN"
                                                 meta="UP" shift="UP" shortcut="UP"/>
                           </accelerator>
                        </MenuItem>
                     </items>
                  </Menu>

                  <!-- Settings menu: UI preferences -->
                  <Menu mnemonicParsing="false" text="Settings">
                     <items>
                        <!-- Toggle dark / light theme without restarting; Ctrl+T ≈ "Theme" -->
                        <MenuItem mnemonicParsing="false" text="Toggle Dark / Light Theme"
                                  onAction="#toggleTheme">
                           <accelerator>
                              <KeyCodeCombination alt="UP" code="T" control="DOWN"
                                                 meta="UP" shift="UP" shortcut="UP"/>
                           </accelerator>
                        </MenuItem>
                     </items>
                  </Menu>

                  <!-- Help menu: documentation and about info -->
                  <Menu mnemonicParsing="false" text="Help">
                     <items>
                        <!-- Shows development challenges and solutions (required by rubric) -->
                        <MenuItem mnemonicParsing="false" text="Challenges &amp; Solutions"
                                  onAction="#showHelpDialog"/>
                        <MenuItem mnemonicParsing="false" text="About"
                                  onAction="#showAboutDialog"/>
                     </items>
                  </Menu>

               </menus>
            </MenuBar>
         </top>

         <!-- ═══════════════════════════════════════════════════════════
              RIGHT — TableView showing all Person records
              Clicking a row populates the input form (selectedItemTV).
         ═══════════════════════════════════════════════════════════ -->
         <right>
            <TableView fx:id="tv" prefHeight="476.0" prefWidth="510.0"
                       BorderPane.alignment="CENTER"
                       onMouseClicked="#selectedItemTV">
               <columns>
                  <TableColumn fx:id="tv_id"   prefWidth="35.0"  text="ID"/>
                  <TableColumn fx:id="tv_fn"   prefWidth="100.0" text="First Name"/>
                  <TableColumn fx:id="tv_ln"   prefWidth="100.0" text="Last Name"/>
                  <TableColumn fx:id="tv_dept" prefWidth="150.0" text="Department"/>
                  <TableColumn fx:id="tv_major" prefWidth="125.0" text="Major"/>
               </columns>
            </TableView>
         </right>

         <!-- ═══════════════════════════════════════════════════════════
              LEFT — Profile picture panel
              Clicking the image opens a FileChooser (showImage).
         ═══════════════════════════════════════════════════════════ -->
         <left>
            <VBox prefHeight="264.0" prefWidth="116.0" styleClass="left_pane"
                  BorderPane.alignment="CENTER">
               <children>
                  <AnchorPane prefHeight="130.0" prefWidth="116.0">
                     <children>
                        <!-- Default profile image; click to browse for a new one -->
                        <ImageView fx:id="img_view"
                                   fitHeight="103.0" fitWidth="85.0"
                                   layoutX="16.0" layoutY="14.0"
                                   onMouseClicked="#showImage"
                                   pickOnBounds="true" preserveRatio="true"
                                   styleClass="profile_pic">
                           <image>
                              <Image url="@images/profile.png"/>
                           </image>
                        </ImageView>
                     </children>
                  </AnchorPane>
               </children>
            </VBox>
         </left>

         <!-- ═══════════════════════════════════════════════════════════
              CENTER — Input form and action buttons
         ═══════════════════════════════════════════════════════════ -->
         <center>
            <VBox prefHeight="476.0" prefWidth="185.0" BorderPane.alignment="CENTER">
               <children>

                  <!-- Input fields — required fields: First Name, Last Name -->
                  <TextField promptText="First Name" fx:id="first_name">
                     <VBox.margin><Insets left="10.0" right="10.0" top="10.0"/></VBox.margin>
                  </TextField>

                  <TextField promptText="Last Name" fx:id="last_name">
                     <VBox.margin><Insets left="10.0" right="10.0" top="8.0"/></VBox.margin>
                  </TextField>

                  <TextField promptText="Department" fx:id="department">
                     <VBox.margin><Insets left="10.0" right="10.0" top="8.0"/></VBox.margin>
                  </TextField>

                  <TextField promptText="Major" fx:id="major">
                     <VBox.margin><Insets left="10.0" right="10.0" top="8.0"/></VBox.margin>
                  </TextField>

                  <!-- Action buttons -->
                  <Button minWidth="-Infinity" mnemonicParsing="false"
                          styleClass="nav_btn" text="Clear" onAction="#clearForm">
                     <VBox.margin><Insets bottom="5.0" left="10.0" right="10.0" top="15.0"/></VBox.margin>
                  </Button>

                  <Button fx:id="addBtn" mnemonicParsing="false"
                          styleClass="nav_btn" text="Add" onAction="#addNewRecord">
                     <VBox.margin><Insets bottom="5.0" left="10.0" right="10.0" top="5.0"/></VBox.margin>
                  </Button>

                  <Button mnemonicParsing="false"
                          styleClass="nav_btn" text="Edit" onAction="#editRecord">
                     <VBox.margin><Insets bottom="5.0" left="10.0" right="10.0" top="5.0"/></VBox.margin>
                  </Button>

                  <Button mnemonicParsing="false"
                          styleClass="nav_btn" text="Delete" onAction="#deleteRecord">
                     <VBox.margin><Insets bottom="5.0" left="10.0" right="10.0" top="5.0"/></VBox.margin>
                  </Button>

               </children>
            </VBox>
         </center>

         <!-- ═══════════════════════════════════════════════════════════
              BOTTOM — Status bar
              Updated by the controller to reflect the result of every action.
         ═══════════════════════════════════════════════════════════ -->
         <bottom>
            <HBox alignment="CENTER_LEFT" prefHeight="32.0" prefWidth="693.0"
                  styleClass="bottom_pane" BorderPane.alignment="CENTER">
               <children>
                  <Label fx:id="statusLabel" styleClass="status-label" text="Ready"/>
               </children>
               <padding><Insets left="8.0"/></padding>
            </HBox>
         </bottom>

      </BorderPane>
   </children>

   <stylesheets>
      <URL value="@styling/style.css"/>
   </stylesheets>

</AnchorPane>
