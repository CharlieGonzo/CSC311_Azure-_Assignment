<?xml version="1.0" encoding="UTF-8"?>

<?import java.net.URL?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<!--
    login.fxml — Login Screen
    Controller: LoginController

    Layout:
      Outer StackPane fills the full window (850×535) and provides
      the gradient background (login-background style class).
      Inner VBox is the centred white login card containing:
        - SUNY Farmingdale logo
        - App title and subtitle
        - Username and Password fields
        - Login button (navigates to main GUI)
        - Register link (navigates to register.fxml)

    Note: Login is UI-only for this lab — no credential check is performed.
-->
<StackPane
        prefHeight="535.0" prefWidth="850.0"
        styleClass="login-background"
        xmlns="http://javafx.com/javafx/20.0.1"
        xmlns:fx="http://javafx.com/fxml/1"
        fx:controller="com.example.module03_basicgui_db_interface.LoginController">

   <stylesheets>
      <URL value="@styling/style.css"/>
   </stylesheets>

   <children>
      <!-- ── Centred login card ───────────────────────────────────── -->
      <VBox alignment="CENTER" spacing="14.0"
            maxWidth="340.0" styleClass="login-card">

         <padding>
            <Insets top="30.0" right="30.0" bottom="30.0" left="30.0"/>
         </padding>

         <children>
            <!-- School logo at the top of the card -->
            <ImageView fitHeight="75.0" fitWidth="160.0" preserveRatio="true">
               <image>
                  <Image url="@images/suny_farmingdale.png"/>
               </image>
            </ImageView>

            <!-- App name and subtitle -->
            <Label styleClass="login-title" text="Person Database"/>
            <Label styleClass="login-subtitle" text="Sign in to manage records"/>

            <!-- Credentials form -->
            <TextField fx:id="usernameField" promptText="Username"
                       maxWidth="Infinity"/>

            <PasswordField fx:id="passwordField" promptText="Password"
                           maxWidth="Infinity"/>

            <!-- Primary action: proceed to the main GUI (no auth check in this lab) -->
            <Button fx:id="loginBtn" styleClass="login-btn" text="Login"
                    onAction="#login" maxWidth="Infinity"/>

            <!-- Secondary action: go to the registration screen -->
            <Button styleClass="link-btn"
                    text="Don't have an account?  Register"
                    onAction="#goToRegister"/>

         </children>
      </VBox>
   </children>

</StackPane>
